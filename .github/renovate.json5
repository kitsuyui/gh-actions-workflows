{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "github>kitsuyui/renovate-config"
  ],
  "packageRules": [
    {
      "description": "Avoid self-referential digest update loops for this reusable workflow repository.",
      "matchManagers": [
        "github-actions"
      ],
      "matchPackageNames": [
        "kitsuyui/gh-actions-workflows"
      ],
      "enabled": false
    }
  ],
  "customManagers": [
    {
      "description": "Track actionlint version embedded in workflow_call input default.",
      "customType": "regex",
      "fileMatch": ["\\.github/workflows/actionlint\\.yml$"],
      "matchStrings": [
        "actionlint-version:[\\s\\S]*?default: \"(?<currentValue>v[0-9]+\\.[0-9]+\\.[0-9]+)\""
      ],
      "datasourceTemplate": "github-releases",
      "depNameTemplate": "rhysd/actionlint"
    }
  ]
}
