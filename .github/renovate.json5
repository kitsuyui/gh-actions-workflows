{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "github>kitsuyui/renovate-config#cdad3c71e34e5abadf909c996906011bbc2b5725"
  ],
  "packageRules": [
    {
      "description": "Avoid self-referential digest update loops for this reusable workflow repository.",
      "matchManagers": [
        "github-actions"
      ],
      "matchPackageNames": [
        "kitsuyui/gh-actions-workflows"
      ],
      "enabled": false
    }
  ]
}
